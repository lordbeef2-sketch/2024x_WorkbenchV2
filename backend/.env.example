# TWC Workbench backend environment configuration
#
# Notes:
# - Lines beginning with # are comments.
# - Keep secrets out of source control in shared environments.
# - JSON-like arrays such as ALLOWED_ORIGINS must stay on one line.
# - TWC_PRESET_SERVERS must stay on one line because it is parsed as JSON.
# - TWC_PRESET_SERVERS is the authoritative preset catalog used before login.

# -----------------------------------------------------------------------------
# Application identity and runtime
# -----------------------------------------------------------------------------

# Human-readable application name used in logs and API metadata.
# Example: APP_NAME=Acme TWC Workbench
APP_NAME=TWC Workbench

# Public origin of this app as seen by the browser in deployed environments.
# Use the Caddy or reverse-proxy hostname that serves the frontend.
# Leave empty in local development to fall back to FRONTEND_ORIGIN.
# Example: APP_ORIGIN=https://twc-workbench.company.com
APP_ORIGIN=

# Runtime environment label.
# Common values: development, test, staging, production
# Example: ENVIRONMENT=production
ENVIRONMENT=development

# Bind address for this FastAPI application.
# This is the local interface the app listens on, not the Teamwork Cloud hostname.
# Use 0.0.0.0 to listen on all interfaces, 127.0.0.1 for local-only,
# or a specific local interface IP. Do not put your public FQDN here.
# Example: HOST=127.0.0.1
HOST=0.0.0.0

# Backend port.
# Example: PORT=8080
PORT=8000

# API route prefix.
# Example: API_PREFIX=/api
API_PREFIX=/api

# Optional reverse-proxy root path when the app is mounted under a subpath.
# Leave empty for normal local development.
# Example: ROOT_PATH=/twc-workbench
ROOT_PATH=

# -----------------------------------------------------------------------------
# Frontend and CORS
# -----------------------------------------------------------------------------

# Primary browser origin used by the frontend.
# Put your public app URL/FQDN here in deployed environments.
# Example: FRONTEND_ORIGIN=https://twc-workbench.company.com
FRONTEND_ORIGIN=http://localhost:5173

# Allowed CORS origins as a JSON array on one line.
# Example: ALLOWED_ORIGINS=["https://twc-workbench.company.com","https://admin.company.com"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# -----------------------------------------------------------------------------
# Storage paths
# -----------------------------------------------------------------------------

# Base directory for SQLite data.
# Example: DATA_DIR=D:/apps/twc-workbench/data
DATA_DIR=./data

# Optional explicit database file path.
# Leave empty to use DATA_DIR/twc_workbench.sqlite3.
# Example: DATABASE_PATH=D:/apps/twc-workbench/data/twc_workbench.sqlite3
DATABASE_PATH=

# Optional explicit export directory retained for internal maintenance utilities.
# It is not exposed as a workspace export/job feature.
# Leave empty to use DATA_DIR/exports.
# Example: EXPORT_DIR=D:/apps/twc-workbench/exports
EXPORT_DIR=

# -----------------------------------------------------------------------------
# Teamwork Cloud preset catalog
# -----------------------------------------------------------------------------

# Global Teamwork Cloud preset catalog loaded at startup and exposed before login.
# This JSON array is the authoritative source for pre-login server discovery.
# Keep it on one line.
# Example: TWC_PRESET_SERVERS=[{"id":"twc-2024x","name":"TWC 2024x","base_url":"https://twc2024.company.com","version":"2024x","verify_tls":true,"ca_bundle_path":null,"enabled":true,"display_order":0},{"id":"twc-2022x","name":"TWC 2022x","base_url":"https://twc2022.company.com","version":"2022x","verify_tls":true,"ca_bundle_path":null,"enabled":true,"display_order":1}]
TWC_PRESET_SERVERS=[]

# Sign In via TWC is the primary path. It uses the TWC Authentication Server
# authorization-code flow, preserves the selected preset server, exchanges the
# returned code for an ID token, and then validates that token against
# /osmc/admin/currentUser.
#
# TWC Authentication Server must have this app's callback URL whitelisted in
# authentication.redirect.uri.whitelist and the client id listed in
# authentication.client.ids.
#
# Client id/secret configured in the TWC Authentication Server.
# Example: TWC_AUTH_CLIENT_ID=twc-workbench
TWC_AUTH_CLIENT_ID=
# Example: TWC_AUTH_CLIENT_SECRET=<authentication.client.secret from webappplatform.properties>
TWC_AUTH_CLIENT_SECRET=
TWC_AUTH_SCOPE=openid

# TWC AuthServer authorization front door. For this deployment the app derives
# https://<selected-twc-host>:8443/authentication/authorize from the selected
# preset server base URL.
# If your SAML/AuthServer endpoint uses a different host or proxy path, set a
# complete URL here. Example:
# TWC_SAML_AUTHORIZE_URL=https://auth.company.com:8443/authentication/authorize
TWC_SAML_AUTHORIZE_URL=

# Used only when TWC_SAML_AUTHORIZE_URL is blank.
# Old values /osmc/authen/login, /osmc/login.html, and
# /authentication/saml2/sso/tssd-twc2024x are normalized to this authorize path
# because they open the wrong login or ACS surface for this app.
TWC_SAML_LOGIN_PATH=/authentication/authorize
TWC_SAML_LOGIN_PORT=8443
TWC_SAML_TOKEN_PATH=/authentication/api/token

# Return URL parameter appended to the TWC AuthServer authorize URL.
# Example: TWC_SAML_RETURN_URL_PARAMETER=redirect_uri
TWC_SAML_RETURN_URL_PARAMETER=redirect_uri

# -----------------------------------------------------------------------------
# Session and security settings
# -----------------------------------------------------------------------------

# Secret used to encrypt server-side delegated credentials and app sessions.
# Replace this with a long random value in non-local environments.
# Example: SESSION_SECRET=8d7f2d4ddc9f43e5abf55d13a6fb7f40f21c7c9e7c6a1b4d
SESSION_SECRET=replace-with-a-32-byte-secret

# Name of the HTTP-only session cookie.
# Example: SESSION_COOKIE_NAME=twc_session_prod
SESSION_COOKIE_NAME=twc_session

# Session lifetime in minutes.
# Example: SESSION_TTL_MINUTES=60
SESSION_TTL_MINUTES=480

# Enable secure cookies when running behind HTTPS.
# Use true in staging/production with TLS.
# Example: SECURE_COOKIES=true
SECURE_COOKIES=false

# Header name used for CSRF protection on state-changing requests.
# Example: CSRF_HEADER_NAME=X-CSRF-Token
CSRF_HEADER_NAME=X-CSRF-Token

# Optional public callback path used by Sign In via TWC.
# Leave empty to use API_PREFIX/auth/callback.
# Set this only when your deployed app must receive the callback on a different
# browser-visible path.
# Example: TWC_AUTH_CALLBACK_PATH=/api/auth/callback
TWC_AUTH_CALLBACK_PATH=

# Optional JSON array of upstream Teamwork Cloud cookie names to forward.
# Leave empty to forward all incoming cookies except the app's own cookies.
# The Sign In via TWC callback succeeds only when authenticated Teamwork Cloud
# session cookies or a forwarded user-scoped TWC token reach the callback.
# Example: UPSTREAM_AUTH_COOKIE_NAMES=["twc-rest-session-id","JSESSIONID"]
UPSTREAM_AUTH_COOKIE_NAMES=[]

# Optional JSON array of trusted reverse-proxy headers that identify the current user.
# These headers are only meaningful when your proxy authenticates the user before
# the app. They do not replace the required Teamwork Cloud session cookies or a
# forwarded user-scoped TWC token for callback completion.
# Example: UPSTREAM_USER_HEADERS=["X-Forwarded-User","Remote-User"]
UPSTREAM_USER_HEADERS=["X-Forwarded-User","Remote-User","X-MS-CLIENT-PRINCIPAL-NAME","X-Authenticated-User"]

# Optional JSON array of trusted reverse-proxy headers that carry TWC group membership.
# When these claims are not available, the app falls back to allowing authenticated users
# to manage preset servers rather than duplicating TWC authorization in app config.
# Example: UPSTREAM_GROUP_HEADERS=["X-Forwarded-Groups","X-Groups"]
UPSTREAM_GROUP_HEADERS=["X-Forwarded-Groups","X-Groups","X-MS-CLIENT-PRINCIPAL-GROUPS","X-Authenticated-Groups"]

# Optional JSON array of trusted reverse-proxy headers that carry TWC role membership.
# Example: UPSTREAM_ROLE_HEADERS=["X-Forwarded-Roles","X-Roles"]
UPSTREAM_ROLE_HEADERS=["X-Forwarded-Roles","X-Roles","X-MS-CLIENT-PRINCIPAL-ROLES","X-Authenticated-Roles"]

# Optional JSON array of trusted reverse-proxy headers that carry a user-scoped TWC token.
# Configure one of these when your deployment returns the browser to the callback
# without forwarding Teamwork Cloud session cookies.
# Example: UPSTREAM_ACCESS_TOKEN_HEADERS=["X-Forwarded-Access-Token","Authorization"]
UPSTREAM_ACCESS_TOKEN_HEADERS=["X-Forwarded-Access-Token","X-Access-Token","Authorization"]

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Logging level.
# Common values: DEBUG, INFO, WARNING, ERROR
# Example: LOG_LEVEL=DEBUG
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional Redis-backed session storage
# -----------------------------------------------------------------------------

# Redis connection string for shared session storage.
# Leave empty to use in-memory sessions.
# Example: REDIS_URL=redis://localhost:6379/0
REDIS_URL=
