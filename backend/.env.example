# TWC Workbench backend environment configuration
#
# Notes:
# - Lines beginning with # are comments.
# - Keep secrets out of source control in shared environments.
# - JSON-like arrays such as ALLOWED_ORIGINS must stay on one line.
# - Do not put Teamwork Cloud target servers or an active TWC server in this file.
# - TWC connection info belongs in user-editable server profiles stored by the application.

# -----------------------------------------------------------------------------
# Application identity and runtime
# -----------------------------------------------------------------------------

# Human-readable application name used in logs and API metadata.
# Example: APP_NAME=Acme TWC Workbench
APP_NAME=TWC Workbench

# Runtime environment label.
# Common values: development, test, staging, production
# Example: ENVIRONMENT=production
ENVIRONMENT=development

# Bind address for this FastAPI application.
# This is the local interface the app listens on, not the Teamwork Cloud hostname.
# Use 0.0.0.0 to listen on all interfaces, 127.0.0.1 for local-only,
# or a specific local interface IP. Do not put your public FQDN here.
# Example: HOST=127.0.0.1
HOST=0.0.0.0

# Backend port.
# Example: PORT=8080
PORT=8000

# API route prefix.
# Example: API_PREFIX=/api
API_PREFIX=/api

# Optional reverse-proxy root path when the app is mounted under a subpath.
# Leave empty for normal local development.
# Example: ROOT_PATH=/twc-workbench
ROOT_PATH=

# -----------------------------------------------------------------------------
# Frontend and CORS
# -----------------------------------------------------------------------------

# Primary browser origin used by the frontend.
# Put your public app URL/FQDN here in deployed environments.
# Example: FRONTEND_ORIGIN=https://twc-workbench.company.com
FRONTEND_ORIGIN=http://localhost:5173

# Allowed CORS origins as a JSON array on one line.
# Example: ALLOWED_ORIGINS=["https://twc-workbench.company.com","https://admin.company.com"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# -----------------------------------------------------------------------------
# Storage and export paths
# -----------------------------------------------------------------------------

# Base directory for SQLite data, fallback workspace content, and generated files.
# Example: DATA_DIR=D:/apps/twc-workbench/data
DATA_DIR=./data

# Optional explicit database file path.
# Leave empty to use DATA_DIR/twc_workbench.sqlite3.
# Example: DATABASE_PATH=D:/apps/twc-workbench/data/twc_workbench.sqlite3
DATABASE_PATH=

# Optional explicit export directory.
# Leave empty to use DATA_DIR/exports.
# Example: EXPORT_DIR=D:/apps/twc-workbench/exports
EXPORT_DIR=

# -----------------------------------------------------------------------------
# Session and security settings
# -----------------------------------------------------------------------------

# Secret used to encrypt server-side delegated credentials and app sessions.
# Replace this with a long random value in non-local environments.
# Example: SESSION_SECRET=8d7f2d4ddc9f43e5abf55d13a6fb7f40f21c7c9e7c6a1b4d
SESSION_SECRET=replace-with-a-32-byte-secret

# Name of the HTTP-only session cookie.
# Example: SESSION_COOKIE_NAME=twc_session_prod
SESSION_COOKIE_NAME=twc_session

# Session lifetime in minutes.
# Example: SESSION_TTL_MINUTES=60
SESSION_TTL_MINUTES=480

# Enable secure cookies when running behind HTTPS.
# Use true in staging/production with TLS.
# Example: SECURE_COOKIES=true
SECURE_COOKIES=false

# Header name used for CSRF protection on state-changing requests.
# Example: CSRF_HEADER_NAME=X-CSRF-Token
CSRF_HEADER_NAME=X-CSRF-Token

# Optional JSON array of upstream Teamwork Cloud cookie names to forward.
# Leave empty to forward all incoming cookies except the app's own session cookie.
# Example: UPSTREAM_AUTH_COOKIE_NAMES=["twc-rest-session-id","JSESSIONID"]
UPSTREAM_AUTH_COOKIE_NAMES=[]

# Optional JSON array of trusted reverse-proxy headers that identify the current user.
# These headers are only meaningful when your proxy authenticates the user before the app.
# Example: UPSTREAM_USER_HEADERS=["X-Forwarded-User","Remote-User"]
UPSTREAM_USER_HEADERS=["X-Forwarded-User","Remote-User","X-MS-CLIENT-PRINCIPAL-NAME","X-Authenticated-User"]

# Optional JSON array of trusted reverse-proxy headers that carry a user-scoped TWC token.
# Example: UPSTREAM_ACCESS_TOKEN_HEADERS=["X-Forwarded-Access-Token","Authorization"]
UPSTREAM_ACCESS_TOKEN_HEADERS=["X-Forwarded-Access-Token","X-Access-Token","Authorization"]

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Logging level.
# Common values: DEBUG, INFO, WARNING, ERROR
# Example: LOG_LEVEL=DEBUG
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional Redis-backed session storage
# -----------------------------------------------------------------------------

# Redis connection string for shared session storage.
# Leave empty to use in-memory sessions.
# Example: REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# -----------------------------------------------------------------------------
# Publish integration
# -----------------------------------------------------------------------------

# Publisher integration mode.
# Supported values: local, cli, webhook
# Example: PUBLISHER_MODE=webhook
PUBLISHER_MODE=local

# External CLI command used when PUBLISHER_MODE=cli.
# Example: PUBLISHER_COMMAND=C:/tools/twc-publisher/publish.exe
PUBLISHER_COMMAND=

# Webhook endpoint used when PUBLISHER_MODE=webhook.
# Example: PUBLISHER_WEBHOOK_URL=https://publisher.company.com/api/jobs/publish
PUBLISHER_WEBHOOK_URL=
